---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home • Tom.exe" active="home">
  <section>
    <h1 transition:animate="slide">Hello. I’m Tom.</h1>
    <p class="muted">
      I build stuff. Sometimes it works. Sometimes it becomes a feature.
    </p>

    <div style="margin: 16px 0 6px">
      <a class="btn" href={new URL('work/', import.meta.env.BASE_URL).pathname}>
        <span aria-hidden="true">▶</span>
        <span>Enter: Work</span>
      </a>
      <span class="muted" style="margin-left: 10px">(Try clicking the tabs up top.)</span>
    </div>

    <div class="grid" style="margin-top: 18px">
      <div class="card half" transition:animate="fade">
        <h2>Now</h2>
        <p class="muted">Designing playful interfaces and shipping tiny experiments.</p>
      </div>
      <div class="card half" transition:animate="fade">
        <h2>Signal</h2>
        <p class="muted">
          Minimal, retro, and interactive — like a good old DOS prompt, but with taste.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
