---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact • Tom.exe" active="contact">
  <section>
    <h1 transition:animate="slide">Contact</h1>
    <p class="muted">Pick a portal. (If you want, we can add a silly “copy to clipboard” interaction.)</p>

    <div class="grid" style="margin-top: 16px">
      <div class="card half" transition:animate="fade">
        <h2>Email</h2>
        <p class="muted"><a href="mailto:you@example.com">you@example.com</a></p>
      </div>
      <div class="card half" transition:animate="fade">
        <h2>Links</h2>
        <p class="muted">
          <a href="#" onclick="event.preventDefault()">GitHub</a> •
          <a href="#" onclick="event.preventDefault()">Twitter</a> •
          <a href="#" onclick="event.preventDefault()">LinkedIn</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
