---
interface Props {
  active: 'home' | 'work' | 'about' | 'contact';
}
const { active } = Astro.props;

const BASE_URL = import.meta.env.BASE_URL;
const withBase = (path: string) => `${BASE_URL}${path.replace(/^\//, '')}`;

const items: Array<{ key: Props['active']; href: string; label: string }> = [
  { key: 'home', href: withBase('/'), label: 'Home' },
  { key: 'work', href: withBase('/work/'), label: 'Work' },
  { key: 'about', href: withBase('/about/'), label: 'About' },
  { key: 'contact', href: withBase('/contact/'), label: 'Contact' },
];
---
<nav class="nav" aria-label="Primary">
  <div class="nav__rail">
    {items.map((it) => (
      <a
        class={"nav__item" + (active === it.key ? " is-active" : "")}
        href={it.href}
        transition:name={active === it.key ? 'nav-pill' : undefined}
      >
        <span class="nav__label">{it.label}</span>
        {active === it.key && <span class="nav__pill" aria-hidden="true"></span>}
      </a>
    ))}
  </div>
</nav>
